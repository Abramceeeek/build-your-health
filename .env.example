# ── Build-your-health environment template ───────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# In production set these as real values on the server; do not ship .env over scp.

# ── Core / required in production ────────────────────────────────────────────
ENVIRONMENT=development                 # set to "production" in prod (enables guards)
# Postgres in prod (SQLite is blocked when ENVIRONMENT=production):
DATABASE_URL=sqlite:///./health_transform.db
# When using the docker-compose Postgres service, set a strong password here and use the
# SAME password inside DATABASE_URL, e.g. postgresql://postgres:<pw>@db:5432/health_transform
# POSTGRES_PASSWORD=change-me-strong
# Public HTTPS origin of the Mini App (tunnel URL in dev). REQUIRED in production.
WEBAPP_URL=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                      # from @BotFather; required for the bot + initData auth
TELEGRAM_BOT_USERNAME=                   # e.g. mygym_bot (no @)

# ── AI providers (at least one recommended; fallback order Gemini→OpenRouter→Anthropic) ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Optional integrations ────────────────────────────────────────────────────
USDA_API_KEY=                            # nutrition search (falls back to DEMO_KEY if empty)
SENTRY_DSN=                              # error tracking (optional)
LOG_JSON=                                # true = structured JSON logs to stdout (prod)

# ── Feedback routing (optional) ──────────────────────────────────────────────
FEEDBACK_CHANNEL_ID=
FEEDBACK_ADMIN_CHAT_ID=
FEEDBACK_BOT_TOKEN=                      # dedicated feedback bot; falls back to TELEGRAM_BOT_TOKEN

# ── Server / runtime ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
UPLOAD_DIR=./uploads/photos

# ── Auth / safety ────────────────────────────────────────────────────────────
DEV_AUTH_ENABLED=true                    # MUST be false (or ENVIRONMENT=production) in prod

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_WEEKLY_HOUR=21
REMINDER_CHECK_INTERVAL_MINUTES=1
